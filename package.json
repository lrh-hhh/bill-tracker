{
  "name": "bill-tracker",
  "version": "1.0.0",
  "description": "一个简洁的个人记账工具，帮助您轻松管理日常收支",
  "private": true,
  "author": "",
  "license": "Apache-2.0",
  "homepage": "https://lrh-hhh.github.io/bill-tracker",
  "repository": {
    "type": "git",
    "url": "https://github.com/lrh-hhh/bill-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/lrh-hhh/bill-tracker/issues"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "test": "concurrently \"npm run test:server\" \"npm run test:client\"",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "bill-tracker",
    "finance",
    "vue3",
    "express",
    "sqlite"
  ]
}
